---
const footerLinks = {
  Leistungen: [
    { label: 'AI-Automatisierungen', href: '/wandasystems-site/services#automation' },
    { label: 'SaaS-Produkte', href: '/wandasystems-site/services#saas' },
    { label: 'API-Integrationen', href: '/wandasystems-site/services#automation' },
    { label: 'AI-Agent-Systeme', href: '/wandasystems-site/services#agents' },
  ],
  Unternehmen: [
    { label: 'Über WandaSystems', href: '/wandasystems-site/company' },
    { label: 'Portfolio', href: '/wandasystems-site/portfolio' },
    { label: 'Kontakt', href: '/wandasystems-site/contact' },
  ],
};
---

<footer class="mt-auto relative border-t border-border" style="background: rgba(10, 10, 10, 0.97);">
  <!-- Top glow line -->
  <div class="absolute top-0 left-0 right-0 glow-divider opacity-40"></div>

  <div class="container-content">
    <!-- Main footer -->
    <div class="grid gap-12 py-16 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/wandasystems-site/" class="flex items-center gap-2.5 no-underline mb-4 group" aria-label="WandaSystems">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <rect width="28" height="28" rx="6" fill="#111111" stroke="rgba(201,168,76,0.4)" stroke-width="1"/>
            <path d="M5 8L9 21L14 15L19 21L23 8" stroke="#f5f5f0" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M7.5 8L9 11.5L14 15L19 11.5L20.5 8" stroke="#c9a84c" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.45"/>
          </svg>
          <span class="text-sm font-semibold text-text-primary group-hover:text-brand-gold transition-colors">WandaSystems</span>
        </a>
        <p class="max-w-xs text-small text-text-secondary leading-relaxed">
          Wir bauen AI-Systeme, die tatsächlich arbeiten — messbar, zuverlässig, profitabel.
        </p>
        <div class="mt-6">
          <a
            href="mailto:wanda.devops@gmail.com"
            class="text-small text-text-muted transition-colors hover:text-brand-gold"
          >
            wanda.devops@gmail.com
          </a>
        </div>
      </div>

      <!-- Links -->
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <p class="label-text mb-4">{category}</p>
          <ul class="flex flex-col gap-2.5" role="list">
            {links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-small text-text-secondary transition-colors hover:text-brand-gold"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col items-center justify-between gap-4 border-t border-border py-6 sm:flex-row">
      <p class="text-xs text-text-muted">
        © 2026 WandaSystems · Hamburg · wanda.devops@gmail.com
      </p>
      <div class="flex items-center gap-6">
        <a href="/wandasystems-site/imprint" class="text-xs text-text-muted transition-colors hover:text-brand-gold">
          Impressum
        </a>
        <a href="/wandasystems-site/privacy" class="text-xs text-text-muted transition-colors hover:text-brand-gold">
          Datenschutz
        </a>
      </div>
    </div>
  </div>
</footer>
