---
import Logo from "./Logo.astro";

const footerLinks = {
  Services: [
    { label: 'AI Automations', href: '/wandasystems-site/services#automation' },
    { label: 'SaaS Products', href: '/wandasystems-site/services#saas' },
    { label: 'Workflow Integrations', href: '/wandasystems-site/services#automation' },
    { label: 'AI Agent Systems', href: '/wandasystems-site/services#agents' },
  ],
  Company: [
    { label: 'About WandaSystems', href: '/wandasystems-site/company' },
    { label: 'Case Studies', href: '/wandasystems-site/cases' },
    { label: 'Contact', href: '/wandasystems-site/contact' },
  ],
};

// ⚡ Bolt: Pre-calculate data transformations in Astro frontmatter
// 💡 What: Extracted `Object.entries(footerLinks)` from the template into the static setup block.
// 🎯 Why: Performing object iterations or data transformations within the template causes redundant recalculations during the rendering phase. Moving it to the frontmatter ensures it executes only once during build time.
// 📊 Impact: Micro-optimization for build speed and reduces template complexity.
const footerLinksEntries = Object.entries(footerLinks);
---

<footer class="mt-auto relative border-t border-border" style="background: rgba(10, 10, 10, 0.97);">
  <!-- Top glow line -->
  <div class="absolute top-0 left-0 right-0 glow-divider opacity-40"></div>

  <div class="container-content">
    <!-- Main footer -->
    <div class="grid gap-12 py-16 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/wandasystems-site/" class="flex items-center gap-2.5 no-underline mb-4 group" aria-label="WandaSystems">
          <Logo />
          <span class="text-sm font-semibold text-text-primary group-hover:text-brand-gold transition-colors">WandaSystems</span>
        </a>
        <p class="max-w-xs text-small text-text-secondary leading-relaxed">
          We build AI systems that actually work — measurable, reliable, profitable.
        </p>
        <div class="mt-6">
          <a
            href="mailto:wanda.devops@gmail.com"
            class="text-small text-text-muted transition-colors hover:text-brand-gold"
          >
            wanda.devops@gmail.com
          </a>
        </div>
      </div>

      <!-- Links -->
      {footerLinksEntries.map(([category, links]) => (
        <div>
          <p class="label-text mb-4">{category}</p>
          <ul class="flex flex-col gap-2.5" role="list">
            {links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-small text-text-secondary transition-colors hover:text-brand-gold"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col items-center justify-between gap-4 border-t border-border py-6 sm:flex-row">
      <p class="text-xs text-text-muted">
        © 2026 WandaSystems · Hamburg · wanda.devops@gmail.com
      </p>
      <div class="flex items-center gap-6">
        <a href="/wandasystems-site/imprint" class="text-xs text-text-muted transition-colors hover:text-brand-gold">
          Imprint
        </a>
        <a href="/wandasystems-site/privacy" class="text-xs text-text-muted transition-colors hover:text-brand-gold">
          Privacy Policy
        </a>
      </div>
    </div>
  </div>
</footer>
