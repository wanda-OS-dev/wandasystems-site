---
import Logo from "./Logo.astro";
const navItems = [
  { label: 'Services', href: '/wandasystems-site/services' },
  { label: 'Case Studies', href: '/wandasystems-site/cases' },
  { label: 'Company', href: '/wandasystems-site/company' },
  { label: 'Contact', href: '/wandasystems-site/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border backdrop-blur-xl" style="background: rgba(10, 10, 10, 0.85);">
  <!-- Subtle bottom glow line -->
  <div class="absolute bottom-0 left-0 right-0 glow-divider opacity-60"></div>

  <div class="container-content">
    <nav class="flex h-16 items-center justify-between" role="navigation" aria-label="Main navigation">
      <!-- Logo -->
      <a
        href="/wandasystems-site/"
        class="flex items-center gap-2.5 no-underline group"
        aria-label="WandaSystems Home"
        aria-current={currentPath === '/wandasystems-site/' || currentPath === '/wandasystems-site' ? 'page' : undefined}
      >
        <div class="relative">
          <Logo />
          <div class="absolute inset-0 rounded-md opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="box-shadow: 0 0 12px rgba(201,168,76,0.4);"></div>
        </div>
        <span class="text-sm font-semibold tracking-tight text-text-primary group-hover:text-brand-gold transition-colors duration-150">WandaSystems</span>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden items-center gap-1 md:flex" role="list">
        {navItems.map((item) => {
          const isActive = currentPath === item.href || currentPath === item.href + '/' || currentPath.startsWith(item.href + '/');
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  'rounded-lg px-4 py-2 text-small font-medium transition-colors duration-150',
                  isActive
                    ? 'bg-brand-indigo-card text-brand-gold border border-brand-gold/20'
                    : 'text-text-secondary hover:bg-white/5 hover:text-text-primary',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- CTA -->
      <div class="flex items-center gap-3">
        <a href="/wandasystems-site/contact" class="btn-primary hidden text-xs sm:inline-flex">
          Book a call
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="flex h-9 w-9 items-center justify-center rounded-lg text-text-secondary transition-colors hover:bg-white/5 hover:text-brand-gold md:hidden"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="menu-icon-open" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" class="block">
            <path d="M3 5h12M3 9h12M3 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <svg id="menu-icon-close" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" class="hidden">
            <path d="M4 4l10 10M14 4L4 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-border md:hidden"
    style="background: rgba(10, 10, 10, 0.97);"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <div class="container-content py-4">
      <ul class="flex flex-col gap-1" role="list">
        {navItems.map((item) => {
          const isActive = currentPath === item.href || currentPath === item.href + '/' || currentPath.startsWith(item.href + '/');
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  'block rounded-lg px-4 py-3 text-small font-medium transition-colors',
                  isActive
                    ? 'bg-brand-indigo-card text-brand-gold'
                    : 'text-text-secondary hover:bg-white/5 hover:text-text-primary',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
        <li class="mt-2 pt-2 border-t border-border">
          <a href="/wandasystems-site/contact" class="btn-primary w-full justify-center text-xs">
            Book a call
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  const toggleMenu = (forceClose = false) => {
    if (!menu || !btn || !iconOpen || !iconClose) return;

    const isOpen = !menu.classList.contains('hidden');
    const willBeOpen = forceClose ? false : !isOpen;

    if (willBeOpen) {
      menu.classList.remove('hidden');
      iconOpen.classList.replace('block', 'hidden');
      iconClose.classList.replace('hidden', 'block');
    } else {
      menu.classList.add('hidden');
      iconOpen.classList.replace('hidden', 'block');
      iconClose.classList.replace('block', 'hidden');
    }

    btn.setAttribute('aria-expanded', String(willBeOpen));
    btn.setAttribute('aria-label', willBeOpen ? 'Close menu' : 'Open menu');
  };

  btn?.addEventListener('click', () => toggleMenu());

  // Close on Escape key press and return focus to button
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu && !menu.classList.contains('hidden')) {
      toggleMenu(true);
      btn?.focus();
    }
  });
</script>
