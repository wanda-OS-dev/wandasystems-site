---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Impressum" description="Impressum WandaSystems">
  <section class="pt-20 pb-32">
    <div class="container-content">
      <span class="badge mb-4 inline-block">Impressum</span>
      <h1 class="text-heading-1 mb-10 text-text-primary">Impressum</h1>

      <div class="prose prose-invert max-w-prose text-text-secondary">
        <h2 class="text-text-primary">Angaben gemäß § 5 TMG</h2>
        <p>
          WandaSystems<br />
          [Straße und Hausnummer]<br />
          [PLZ] Hamburg<br />
          Deutschland
        </p>

        <h2 class="text-text-primary">Kontakt</h2>
        <p>
          E-Mail: <a href="mailto:wanda.devops@gmail.com" class="text-accent hover:underline">wanda.devops@gmail.com</a>
        </p>

        <h2 class="text-text-primary">Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV</h2>
        <p>[Name, Anschrift wie oben]</p>

        <p class="text-text-muted text-small mt-8">
          Bitte ersetzen Sie die Platzhalter mit Ihren tatsächlichen Angaben vor dem Launch.
        </p>
      </div>
    </div>
  </section>
</Layout>
