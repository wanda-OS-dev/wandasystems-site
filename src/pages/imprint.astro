---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Imprint" description="Imprint WandaSystems">
  <section class="pt-20 pb-32">
    <div class="container-content">
      <span class="badge mb-4 inline-block">Imprint</span>
      <h1 class="text-heading-1 mb-10 text-text-primary">Imprint</h1>

      <div class="prose prose-invert max-w-prose text-text-secondary">
        <h2 class="text-text-primary">Provider Information</h2>
        <p>
          WandaSystems<br />
          Hamburg, Germany
        </p>

        <h2 class="text-text-primary">Contact</h2>
        <p>
          Email: <a href="mailto:wanda.devops@gmail.com" class="text-brand-gold hover:underline">wanda.devops@gmail.com</a>
        </p>

        <h2 class="text-text-primary">Content Responsibility</h2>
        <p>
          Responsible for editorial content: WandaSystems.
        </p>
      </div>
    </div>
  </section>
</Layout>
