---
import Layout from '../layouts/Layout.astro';
import { sanitizeSVG } from '../utils/sanitize';

const metrics = [
  { value: '40%+', label: 'Ø Cost reduction through automation' },
  { value: '< 8W', label: 'Time-to-Production for AI systems' },
  { value: '24/7', label: 'Autonomous agents without downtime' },
  { value: '100%', label: 'Custom built — no generic templates' },
];

const services = [
  {
    id: 'automation',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2L3 6v8l7 4 7-4V6L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M10 2v12M3 6l7 4 7-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    title: 'AI Automations',
    desc: 'Eliminate repetitive workflows. n8n + Python pipelines that execute your processes around the clock — without errors, without overhead.',
    href: '/wandasystems-site/services#automation',
  },
  {
    id: 'saas',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2" y="3" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M6 17h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M8 7h4M8 10h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: 'SaaS Products',
    desc: 'Complete SaaS platforms based on SupaStarter. From idea to market-ready product in weeks, not months.',
    href: '/wandasystems-site/services#saas',
  },
  {
    id: 'web-app',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><rect x="2.5" y="3" width="15" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M7 16.5h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M10 13v3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: 'Web & App Development',
    desc: 'High-performance web apps and internal platforms with a clear focus on UX, speed, and measurable business results.',
    href: '/wandasystems-site/services#saas',
  },
  {
    id: 'agents',
    icon: `<svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="8" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M5 17c0-2.761 2.239-5 5-5s5 2.239 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M15 5l2-2M15 11l2 2M5 5L3 3M5 11L3 13" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>`,
    title: 'AI Agent Systems',
    desc: 'Custom agents that think, plan, and act. Orchestrated multi-agent architectures for complex enterprise operations.',
    href: '/wandasystems-site/services#agents',
  },
];
---

<Layout
  title="AI systems that work"
  description="WandaSystems builds AI automations, SaaS products, and API integrations for B2B companies that need results — not promises."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden pt-20 pb-24 lg:pt-28 lg:pb-32" aria-labelledby="hero-headline">
    <!-- Atmospheric aurora effects — premium gold -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <!-- Grid pattern -->
      <div class="absolute inset-0" style="background-image: linear-gradient(to right, rgba(201,168,76,0.03) 1px, transparent 1px), linear-gradient(to bottom, rgba(201,168,76,0.03) 1px, transparent 1px); background-size: 60px 60px;"></div>
      <!-- Aurora blobs -->
      <div class="hero-aurora hero-aurora-1"></div>
      <div class="hero-aurora hero-aurora-2"></div>
      <!-- Radial depth -->
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 50%, rgba(201, 168, 76, 0.05) 0%, transparent 60%);"></div>
      <!-- Bottom fade -->
      <div class="absolute bottom-0 left-0 right-0 h-48" style="background: linear-gradient(to top, #0a0a0a, transparent);"></div>
    </div>

    <div class="container-content relative">
      <div class="mx-auto max-w-[860px]">
        <!-- Label -->
        <div class="mb-8 flex items-center gap-3">
          <span class="badge">B2B AI Systems</span>
          <span class="label-text text-text-muted">Hamburg · Remote</span>
        </div>

        <!-- Headline -->
        <h1 id="hero-headline" class="text-display mb-6 text-text-primary">
          We build AI systems<br class="hidden sm:block" />
          <span class="text-gradient-gold">that actually work.</span>
        </h1>

        <!-- Sub -->
        <p class="mb-10 max-w-[560px] text-body-lg text-text-secondary">
          No demos. No buzzwords. WandaSystems delivers AI automations,
          SaaS products, and API integrations that produce measurable results — with visible proof, not empty claims.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-4">
          <a href="https://buy.stripe.com/28E14odfd8u6gPqbkQaVa01" target="_blank" rel="noopener noreferrer" class="btn-primary">
            Buy Data Cleaning Bot — €29
            <span class="sr-only">(opens in a new tab)</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/wandasystems-site/services#products-heading" class="btn-secondary">
            View instant products
          </a>
        </div>
        <p class="mt-4 max-w-[560px] text-small text-text-muted">
          Fastest live path right now: direct-buy utility tools with fulfillment email after Stripe confirmation.
        </p>
      </div>
    </div>
  </section>

  <!-- Metrics bar -->
  <section class="border-y border-border py-12 relative" aria-label="Key metrics" style="background: linear-gradient(135deg, rgba(18, 8, 32, 0.9) 0%, rgba(10, 10, 10, 0.95) 100%);">
    <div class="absolute top-0 left-0 right-0 glow-divider opacity-30"></div>
    <div class="container-content">
      <dl class="grid grid-cols-2 gap-8 sm:grid-cols-4">
        {metrics.map((m) => (
          <div class="text-center group">
            <dt class="text-heading-2 font-semibold text-brand-gold group-hover:text-brand-white transition-colors duration-300">{m.value}</dt>
            <dd class="mt-1 text-small text-text-muted">{m.label}</dd>
          </div>
        ))}
      </dl>
    </div>
    <div class="absolute bottom-0 left-0 right-0 glow-divider opacity-30"></div>
  </section>

  <!-- Services Overview -->
  <section class="section" aria-labelledby="services-heading">
    <div class="container-content">
      <div class="mb-14">
        <p class="label-text mb-3">What we build</p>
        <h2 id="services-heading" class="text-heading-1 text-text-primary">
          Four core competencies.<br class="hidden sm:block" />
          One goal: Your growth.
        </h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {services.map((s) => (
          <a href={s.href} class="card spotlight-card group relative flex flex-col gap-4 no-underline">
            <!-- Glow accent on hover -->
            <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" style="background: radial-gradient(600px circle at var(--mouse-x) var(--mouse-y), rgba(201,168,76,0.12), transparent 40%);"></div>
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-gold/10 text-brand-gold transition-colors group-hover:bg-brand-gold/20 relative z-10">
              <Fragment set:html={sanitizeSVG(s.icon)} />
            </div>
            <div class="relative z-10">
              <h3 class="mb-2 text-small font-semibold text-text-primary">{s.title}</h3>
              <p class="text-small text-text-secondary leading-relaxed">{s.desc}</p>
            </div>
            <div class="mt-auto flex items-center gap-1.5 text-xs font-medium text-brand-gold relative z-10">
              Learn more
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2.5 6h7M7 3.5l2.5 2.5L7 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Value Prop / Why WandaSystems -->
  <section class="section border-t border-border relative" aria-labelledby="why-heading">
    <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(180deg, transparent 0%, rgba(201, 168, 76, 0.03) 50%, transparent 100%);"></div>
    <div class="container-content relative">
      <div class="grid gap-16 lg:grid-cols-2 lg:gap-24 items-start">
        <!-- Left: Text -->
        <div>
          <p class="label-text mb-4">Why WandaSystems</p>
          <h2 id="why-heading" class="text-heading-1 mb-6 text-text-primary">
            Not an agency.<br />A technical partner.
          </h2>
          <p class="text-body-lg text-text-secondary mb-8">
            WandaSystems is not a consultancy with PowerPoint decks.
            We write code, deploy systems, and deliver results.
            Our team thinks like engineers — and acts like entrepreneurs.
          </p>

          <ul class="flex flex-col gap-4" role="list">
            {[
              ['Measurable ROI', 'Every project has defined KPIs. If we cannot deliver, we talk about it openly.'],
              ['No lock-ins', 'Open stack. You own the code. No vendor lock-in, no hidden costs.'],
              ['Time is money', 'We deliver in sprints — not after 6-month consulting projects.'],
            ].map(([title, text]) => (
              <li class="flex gap-4">
                <div class="mt-1 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-brand-gold/10">
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                    <path d="M2 5l2 2 4-4" stroke="#c9a84c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <div>
                  <p class="text-small font-semibold text-text-primary">{title}</p>
                  <p class="text-small text-text-secondary">{text}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: Process steps -->
        <div class="space-y-6">
          <p class="label-text mb-6">Our Process</p>
          {[
            { step: '01', title: 'Analysis', desc: 'We understand your problem. 60-minute deep dive, free of charge.' },
            { step: '02', title: 'Architecture', desc: 'Clear technical specification. What we build and why.' },
            { step: '03', title: 'Sprint Execution', desc: 'Weekly delivery packages. No black-box development.' },
            { step: '04', title: 'Go-Live & Operations', desc: 'Deployment, monitoring, iteration. We stay accountable.' },
          ].map((p) => (
            <div class="flex gap-5 group">
              <div class="label-text text-brand-gold w-6 flex-shrink-0 pt-1 group-hover:text-brand-white transition-colors">{p.step}</div>
              <div class="pb-6 border-b border-border last:border-0">
                <p class="font-semibold text-text-primary text-small mb-1">{p.title}</p>
                <p class="text-small text-text-secondary">{p.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section border-t border-border" aria-labelledby="cta-heading">
    <div class="container-content">
      <div class="mx-auto max-w-2xl rounded-2xl p-12 text-center relative overflow-hidden" style="background: linear-gradient(135deg, rgba(18, 8, 32, 0.9) 0%, rgba(10, 10, 10, 0.95) 100%); border: 1px solid rgba(201, 168, 76, 0.1);">
        <!-- Glow effect -->
        <div class="absolute inset-0 pointer-events-none rounded-2xl" style="box-shadow: inset 0 0 60px rgba(201,168,76,0.03), 0 0 60px rgba(201,168,76,0.05);"></div>
        <!-- Corner accents -->
        <div class="absolute top-0 left-0 w-16 h-16 pointer-events-none" style="background: linear-gradient(135deg, rgba(201,168,76,0.1), transparent);"></div>
        <div class="absolute bottom-0 right-0 w-16 h-16 pointer-events-none" style="background: linear-gradient(315deg, rgba(201,168,76,0.1), transparent);"></div>

        <h2 id="cta-heading" class="text-heading-2 mb-4 text-text-primary relative">
          Ready to get started?
        </h2>
        <p class="mb-8 text-body text-text-secondary relative">
          The first consultation is always free. No pitch — we listen,
          then we honestly tell you if and how we can help.
        </p>
        <a href="/wandasystems-site/contact" class="btn-primary relative">
          Book a call now
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <style>
    .hero-aurora {
      position: absolute;
      filter: blur(80px);
      border-radius: 9999px;
      animation: floatAurora 14s ease-in-out infinite;
      will-change: transform;
    }

    .hero-aurora-1 {
      width: 32rem;
      height: 32rem;
      left: -8rem;
      top: -6rem;
      background: radial-gradient(circle, rgba(201, 168, 76, 0.1) 0%, rgba(201, 168, 76, 0) 70%);
      opacity: 0.5;
      animation-delay: -2s;
    }

    .hero-aurora-2 {
      width: 28rem;
      height: 28rem;
      right: -6rem;
      top: 0rem;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0) 70%);
      opacity: 0.3;
      animation-duration: 18s;
    }

    @keyframes floatAurora {
      0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
      50% { transform: translate3d(0, -14px, 0) scale(1.06); }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-aurora {
        animation: none;
      }
    }
  </style>

  <script>
    // 🎨 Palette: Interactive spotlight effect for service cards
    // This adds a mouse-following glow that makes the "boring" cards feel dynamic.
    const cards = document.querySelectorAll('.spotlight-card');

    // ⚡ Bolt: Cache getBoundingClientRect() to prevent layout thrashing on high-frequency mousemove events.
    // 💡 What: Cached DOM rects in a WeakMap and invalidated them on scroll/resize.
    // 🎯 Why: getBoundingClientRect() forces synchronous layout recalculation. Calling it on every mousemove degrades performance.
    // 📊 Impact: Smoother 60fps animations and reduced main-thread blocking time during interaction.
    const rectCache = new WeakMap<HTMLElement, DOMRect>();

    const invalidateCache = () => {
      cards.forEach(card => rectCache.delete(card as HTMLElement));
    };

    window.addEventListener('resize', invalidateCache, { passive: true });
    window.addEventListener('scroll', invalidateCache, { passive: true });

    // ⚡ Bolt: Use requestAnimationFrame to throttle high-frequency style updates
    // 💡 What: Wrapped CSS custom property updates inside a requestAnimationFrame callback, canceling any pending frames on new events.
    // 🎯 Why: mousemove events fire faster than the screen refreshes (e.g. 1000Hz vs 60Hz). Synchronous DOM style updates block the main thread.
    // 📊 Impact: Prevents layout thrashing and ensures smooth 60fps rendering during interactive animations.
    cards.forEach((card) => {
      let rafId: number | null = null;
      card.addEventListener('mousemove', (e) => {
        if (rafId) {
          cancelAnimationFrame(rafId);
        }

        rafId = requestAnimationFrame(() => {
          const mouseEvent = e as MouseEvent;
          const target = card as HTMLElement;

          let rect = rectCache.get(target);
          if (!rect) {
            rect = target.getBoundingClientRect();
            rectCache.set(target, rect);
          }

          const x = mouseEvent.clientX - rect.left;
          const y = mouseEvent.clientY - rect.top;

          target.style.setProperty('--mouse-x', `${x}px`);
          target.style.setProperty('--mouse-y', `${y}px`);
        });
      });
    });
  </script>
</Layout>
