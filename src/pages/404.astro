---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Seite nicht gefunden" description="Diese Seite existiert nicht.">
  <section class="section flex min-h-[60vh] items-center">
    <div class="container-content text-center">
      <p class="label-text mb-4">404</p>
      <h1 class="text-heading-1 mb-5 text-text-primary">Seite nicht gefunden.</h1>
      <p class="text-body text-text-secondary mb-8 max-w-sm mx-auto">
        Diese Seite existiert nicht oder wurde verschoben.
      </p>
      <a href="/" class="btn-primary">
        Zurück zur Startseite
      </a>
    </div>
  </section>
</Layout>
