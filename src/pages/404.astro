---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page not found" description="This page does not exist.">
  <section class="section flex min-h-[60vh] items-center">
    <div class="container-content text-center">
      <p class="label-text mb-4">404</p>
      <h1 class="text-heading-1 mb-5 text-text-primary">Page not found.</h1>
      <p class="text-body text-text-secondary mb-8 max-w-sm mx-auto">
        This page does not exist or was moved.
      </p>
      <a href="/wandasystems-site/" class="btn-primary">
        Back to homepage
      </a>
    </div>
  </section>
</Layout>
