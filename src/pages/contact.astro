---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm';

const contactInfo = [
  {
    label: 'E-Mail',
    value: 'wanda.devops@gmail.com',
    href: 'mailto:wanda.devops@gmail.com',
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="4" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M2 6.5L9 11l7-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    label: 'Antwortzeit',
    value: 'Innerhalb von 24h',
    href: null,
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M9 5.5v3.5l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    label: 'Standort',
    value: 'Hamburg, Deutschland · Remote',
    href: null,
    icon: `<svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 2C6.24 2 4 4.24 4 7c0 3.75 5 9 5 9s5-5.25 5-9c0-2.76-2.24-5-5-5z" stroke="currentColor" stroke-width="1.5"/><circle cx="9" cy="7" r="1.5" stroke="currentColor" stroke-width="1.5"/></svg>`,
  },
];
---

<Layout
  title="Kontakt"
  description="Kostenloses Erstgespräch mit WandaSystems. Kein Pitch, keine Verpflichtung — wir hören zu und sagen Ihnen ehrlich, wie wir helfen können."
>
  <!-- Header -->
  <section class="pt-20 pb-16" aria-labelledby="contact-heading">
    <div class="container-content">
      <span class="badge mb-4 inline-block">Kontakt</span>
      <h1 id="contact-heading" class="text-heading-1 mb-5 text-text-primary max-w-xl">
        Lassen Sie uns sprechen.
      </h1>
      <p class="text-body-lg text-text-secondary max-w-lg">
        Kein Pitch. Kein Template-Angebot. Erstes Gespräch ist immer kostenlos
        — wir hören zu, dann sagen wir ehrlich was möglich ist.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section border-t border-border" aria-label="Kontaktformular und -informationen">
    <div class="container-content">
      <div class="grid gap-16 lg:grid-cols-3 lg:gap-20">
        <!-- Left: Info -->
        <div class="lg:col-span-1">
          <div class="space-y-6 mb-10">
            {contactInfo.map((item) => (
              <div class="flex items-start gap-4">
                <div class="flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
                  <Fragment set:html={item.icon} />
                </div>
                <div>
                  <p class="label-text mb-1">{item.label}</p>
                  {item.href ? (
                    <a
                      href={item.href}
                      class="text-small text-text-primary transition-colors hover:text-accent"
                    >
                      {item.value}
                    </a>
                  ) : (
                    <p class="text-small text-text-primary">{item.value}</p>
                  )}
                </div>
              </div>
            ))}
          </div>

          <!-- What to expect -->
          <div class="rounded-xl border border-border bg-bg-card p-6">
            <p class="label-text mb-4">Was Sie erwartet</p>
            <ol class="space-y-3" role="list">
              {[
                'Erstes Gespräch: 30-60 Minuten, kostenlos',
                'Wir stellen Fragen, kein Pitch',
                'Danach: klare Einschätzung ob + wie wir helfen',
                'Angebot in 48h wenn Fit besteht',
              ].map((step, i) => (
                <li class="flex items-start gap-3">
                  <span class="label-text text-accent w-4 flex-shrink-0 mt-0.5">{String(i + 1).padStart(2, '0')}</span>
                  <span class="text-small text-text-secondary">{step}</span>
                </li>
              ))}
            </ol>
          </div>
        </div>

        <!-- Right: Form (React Island) -->
        <div class="lg:col-span-2">
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>
</Layout>
