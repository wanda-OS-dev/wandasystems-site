---
import Layout from '../layouts/Layout.astro';

const values = [
  {
    title: 'Outcome-Driven',
    desc: 'We measure our success by your success. No hourly billing games, no complexity theater — outcome first.',
  },
  {
    title: 'Technical Honesty',
    desc: 'We tell you when something does not make sense. No over-engineering, no under-delivery.',
  },
  {
    title: 'Speed with Structure',
    desc: 'Fast through clarity, not shortcuts. Solid architecture is always faster than technical debt.',
  },
  {
    title: 'Long-Term Partnership',
    desc: 'We build systems that work without us — and relationships that still bring us back.',
  },
];

const capabilities = [
  'Python Backend Development',
  'n8n Workflow Automation',
  'LLM Integration (OpenAI, Anthropic)',
  'Multi-Agent Architectures',
  'SaaS Product Development',
  'Supabase / PostgreSQL',
  'API Integrations',
  'Business Systems Architecture',
  'Next.js / Astro Frontend',
  'CI/CD & DevOps',
  'REST API Design',
  'Stripe / Payment Integration',
];
---

<Layout
  title="Company"
  description="WandaSystems — who we are, how we think, and why we exist."
>
  <!-- Header -->
  <section class="pt-20 pb-16" aria-labelledby="company-heading">
    <div class="container-content">
      <span class="badge mb-4 inline-block">Company</span>
      <h1 id="company-heading" class="text-heading-1 mb-5 text-text-primary max-w-2xl">
        We build systems<br />that work while we sleep.
      </h1>
      <p class="text-body-lg text-text-secondary max-w-xl">
        WandaSystems is a technical studio for AI automation,
        SaaS, and digital product development. Remote-first, outcome-driven,
        no gimmicks.
      </p>
    </div>
  </section>

  <!-- Origin / Mission -->
  <section class="section border-t border-border" aria-labelledby="mission-heading">
    <div class="container-content">
      <div class="grid gap-16 lg:grid-cols-2 items-start">
        <div>
          <p class="label-text mb-4">Mission</p>
          <h2 id="mission-heading" class="text-heading-2 mb-6 text-text-primary">
            AI should work for businesses<br />— not the other way around.
          </h2>
          <div class="space-y-4 text-body text-text-secondary">
            <p>
              WandaSystems was founded because we saw the promise of AI tools for businesses
              broken too often: demos that fail in production, chatbots that reduce no workload,
              and consulting decks that end up in drawers.
            </p>
            <p>
              We believe AI creates value when it works quietly in the background —
              embedded into processes, reliable, measurable. No technology for technology’s sake.
            </p>
            <p>
              Our approach: understand what is truly needed. Build the simplest thing
              that works. Ship it. Then iterate.
            </p>
          </div>
        </div>

        <div class="space-y-6">
          <p class="label-text mb-2">Vision</p>
          <blockquote class="relative rounded-2xl border border-border bg-bg-card p-8">
            <p class="text-heading-3 font-medium text-text-primary leading-relaxed">
              "The autonomous company is not a concept for 2035. We build it now — process by process."
            </p>
          </blockquote>

          <div class="rounded-xl border border-border bg-bg-card p-6">
            <p class="label-text mb-4">What defines us</p>
            <ul class="space-y-2" role="list">
              {['Remote-first, async by default', 'Open source where practical', 'No lock-in, no nonsense', 'Measurable KPIs for every project'].map((item) => (
                <li class="flex items-center gap-3">
                  <svg class="text-brand-gold flex-shrink-0" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M2.5 7l3 3 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="text-small text-text-secondary">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section border-t border-border bg-bg-secondary" aria-labelledby="values-heading">
    <div class="container-content">
      <p class="label-text mb-4">Values</p>
      <h2 id="values-heading" class="text-heading-2 mb-12 text-text-primary max-w-lg">
        How we think and operate.
      </h2>

      <div class="grid gap-6 sm:grid-cols-2">
        {values.map((v) => (
          <div class="card">
            <h3 class="mb-2 text-small font-semibold text-text-primary">{v.title}</h3>
            <p class="text-small text-text-secondary leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="section border-t border-border" aria-labelledby="capabilities-heading">
    <div class="container-content">
      <div class="grid gap-16 lg:grid-cols-2 items-start">
        <div>
          <p class="label-text mb-4">Capabilities</p>
          <h2 id="capabilities-heading" class="text-heading-2 mb-6 text-text-primary">
            Technologies we use every day.
          </h2>
          <p class="text-body text-text-secondary mb-8">
            No technology bingo. Only tools we actually use to build productive
            systems — and know deeply.
          </p>
          <a href="/wandasystems-site/contact" class="btn-primary">
            Request project scope
          </a>
        </div>

        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
          {capabilities.map((cap) => (
            <div class="flex items-center gap-2 rounded-lg border border-border bg-bg-card px-4 py-3">
              <div class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-brand-gold"></div>
              <span class="text-xs font-medium text-text-secondary">{cap}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Teaser -->
  <section class="section border-t border-border" aria-labelledby="company-cta">
    <div class="container-content">
      <div class="mx-auto max-w-2xl rounded-2xl border border-white/5 bg-gradient-to-br from-brand-gold/5 to-transparent p-12 text-center">
        <h2 id="company-cta" class="text-heading-2 mb-4 text-text-primary">
          Sounds like the right partner?
        </h2>
        <p class="text-body text-text-secondary mb-8">
          Happy to talk. No pitch deck, no form friction —
          direct conversation, honest assessment.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/wandasystems-site/contact" class="btn-primary">Book a call</a>
          <a href="mailto:wanda.devops@gmail.com" class="btn-secondary">
            wanda.devops@gmail.com
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
