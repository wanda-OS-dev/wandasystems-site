---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank you" description="Payment received. Here is what happens next.">
  <section class="section pt-24" aria-labelledby="thanks-heading">
    <div class="container-content max-w-2xl">
      <span class="badge">Payment confirmed</span>
      <h1 id="thanks-heading" class="text-heading-1 mt-4 mb-4">Thank you — your order is in fulfillment.</h1>
      <p class="text-body text-text-secondary mb-6">
        You will receive your fulfillment bundle link within <strong>15 minutes</strong>.
        If delivery takes longer, manual fallback is activated and completed within <strong>60 minutes max</strong>.
      </p>

      <div class="rounded-xl border border-border p-6 mb-6" style="background: rgba(18,8,32,0.6);">
        <p class="label-text mb-3">What happens next</p>
        <ul class="space-y-2 text-small text-text-secondary" role="list">
          <li>1) Stripe payment is verified</li>
          <li>2) Your product bundle is prepared and quality-checked</li>
          <li>3) Delivery message is sent with bundle access</li>
          <li>4) Delivery evidence is logged for audit</li>
        </ul>
      </div>

      <p class="text-small text-text-secondary">
        Need help now? Email
        <a href="mailto:wanda.devops@gmail.com" class="text-brand-gold hover:underline">wanda.devops@gmail.com</a>
        with your order reference.
      </p>
    </div>
  </section>
</Layout>
