---
import Layout from '../layouts/Layout.astro';

const portfolioItems = [
  {
    title: 'Lead-Qualifizierung Automatisierung',
    industry: 'B2B SaaS',
    summary: 'Automatisierte Eingangs-Lead-Qualifizierung und CRM-Übergabe mit messbarer Reaktionszeitreduzierung.',
    result: 'Reaktionszeit von Stunden auf Minuten gesenkt.',
  },
  {
    title: 'SaaS-Produktaufbau',
    industry: 'PropTech',
    summary: 'Produktionsreifes SaaS-Fundament mit Payments, Auth und Analytics in einem Sprint-Track geliefert.',
    result: 'Erste zahlende Nutzer in Woche eins nach Launch.',
  },
  {
    title: 'Echtzeit-Datensync-Pipeline',
    industry: 'E-Commerce',
    summary: 'Shop, CRM und ERP mit zuverlässiger Retry-Logik und Monitoring verbunden.',
    result: 'Datenfehler-Vorfälle signifikant reduziert.',
  },
];
---

<Layout
  title="Portfolio"
  description="Selected WandaSystems delivery outcomes across automation, SaaS, and integrations."
>
  <section class="pt-20 pb-16" aria-labelledby="portfolio-heading">
    <div class="container-content">
      <span class="badge mb-4 inline-block">Portfolio</span>
      <h1 id="portfolio-heading" class="text-heading-1 mb-5 text-text-primary max-w-2xl">
        Ausgewählte Projektergebnisse.
      </h1>
      <p class="text-body-lg text-text-secondary max-w-xl">
        Automatisierungen, SaaS-Builds und Integrationen — mit messbaren Ergebnissen für B2B-Teams.
      </p>
    </div>
  </section>

  <section class="section border-t border-border" aria-labelledby="portfolio-list-heading">
    <div class="container-content">
      <h2 id="portfolio-list-heading" class="sr-only">Portfolio highlights</h2>
      <div class="grid gap-6 md:grid-cols-3">
        {portfolioItems.map((item) => (
          <article class="rounded-2xl border border-border p-6" style="background: linear-gradient(135deg, rgba(18, 8, 32, 0.8) 0%, rgba(10, 10, 10, 0.7) 100%);">
            <p class="label-text mb-3">{item.industry}</p>
            <h3 class="text-heading-3 mb-3 text-text-primary">{item.title}</h3>
            <p class="text-small text-text-secondary mb-4">{item.summary}</p>
            <p class="text-small text-brand-gold">{item.result}</p>
          </article>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href="/wandasystems-site/contact" class="btn-primary">Projekt besprechen</a>
      </div>
    </div>
  </section>
</Layout>
