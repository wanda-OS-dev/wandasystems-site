---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'automation',
    badge: 'AI-Automatisierungen',
    title: 'Prozesse automatisieren.\nOperativen Overhead eliminieren.',
    desc: 'Manuell, repetitiv, fehleranfällig — das sind die drei teuersten Adjektive im Unternehmen. Wir ersetzen sie durch Pipelines, die selbst laufen.',
    detail: `Wir analysieren Ihre Workflows und identifizieren, welche Prozesse sich für Automatisierung eignen. 
    Anschließend bauen wir n8n-Workflows und Python-Pipelines, die zuverlässig, überwachbar und wartbar sind — 
    kein Blackbox-Code, den nur ein Consultant versteht.`,
    stack: ['n8n', 'Python', 'FastAPI', 'PostgreSQL', 'Docker', 'Webhook-Integrationen'],
    outcomes: [
      'Manuelle Dateneingabe auf 0 reduziert',
      'API-Integrationen zwischen allen Business-Tools',
      'Monitoring & Alerting für jeden kritischen Schritt',
      'Dokumentation und Übergabe für interne Teams',
    ],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L3 7v10l9 5 9-5V7L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M12 2v14M3 7l9 5 9-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    id: 'saas',
    badge: 'SaaS-Produkte',
    title: 'Von der Idee zum\nmarktfähigen Produkt.',
    desc: 'SaaS ist ein Kapital-Multiplikator — aber nur wenn die Architektur von Anfang an skaliert. Wir bauen auf bewährtem Stack, der wächst wenn Sie wachsen.',
    detail: `Auf Basis von SupaStarter liefern wir komplette SaaS-Plattformen mit Authentifizierung, Subscription-Management, 
    Dashboard und Admin-Panel. Der Fokus liegt auf Time-to-Market: In 4–8 Wochen von Idee zur ersten zahlenden Subscription.`,
    stack: ['Next.js / Astro', 'Supabase', 'Stripe', 'TypeScript', 'Tailwind CSS', 'Vercel/Cloudflare'],
    outcomes: [
      'Vollständiges Auth-System (OAuth, MFA)',
      'Stripe-Integration für Subscriptions und One-Time Payments',
      'Multi-Tenant-Architektur von Anfang an',
      'Admin-Dashboard & Usage-Analytics',
    ],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M7 8h4M7 11.5h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    id: 'trading',
    badge: 'Trading-Algorithmen',
    title: 'Quantitative Strategien.\nVollständig automatisiert.',
    desc: 'Crypto-Märkte schlafen nicht. Unsere Algorithmen auch nicht. Wir entwickeln, backtesten und deployen quantitative Handelsstrategien für Ihre Anforderungen.',
    detail: `Wir entwickeln regelbasierte und ML-gestützte Handelsstrategien für Crypto-Märkte. 
    Jede Strategie wird gegen historische Daten backtested, mit Walk-Forward-Optimierung validiert und 
    mit striktem Risk-Management deployed. Live-Monitoring und automatische Position-Limits inklusive.`,
    stack: ['Python', 'CCXT', 'pandas', 'TA-Lib', 'PostgreSQL', 'Exchange-APIs'],
    outcomes: [
      'Vollständiges Backtesting mit realistischen Transaktionskosten',
      'Live-Execution auf Major Exchanges (Binance, Bybit, u.a.)',
      'Risk-Management: Max Drawdown, Position Sizing',
      'Performance-Dashboard mit Key-Metriken',
    ],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 16l5-6 4 4 5-8 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 21H3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    id: 'agents',
    badge: 'AI-Agent-Systeme',
    title: 'Agenten, die planen,\nentscheiden und handeln.',
    desc: 'Über Chatbots hinaus: Echte AI-Agenten-Systeme, die komplexe Aufgaben autonom abarbeiten — mit Werkzeugen, Gedächtnis und Business-Logik.',
    detail: `Wir bauen multi-agentische Systeme für komplexe Unternehmensabläufe: Agenten, die eigenständig 
    recherchieren, Code schreiben, Entscheidungen treffen und APIs aufrufen. Eingebettet in Ihre bestehende 
    Infrastruktur, mit klaren Guardrails und menschlicher Oversight wo sie gebraucht wird.`,
    stack: ['Python', 'LangGraph / CrewAI', 'OpenAI / Anthropic', 'Vector DBs', 'REST APIs', 'Docker'],
    outcomes: [
      'Custom-Agenten für Ihre spezifischen Workflows',
      'Tool-Nutzung: Web, DB, APIs, Code-Execution',
      'Persistentes Gedächtnis und Kontext-Management',
      'Human-in-the-loop für kritische Entscheidungen',
    ],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="9" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M6 20c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M18 6l2.5-2.5M18 13l2.5 2.5M6 6L3.5 3.5M6 13L3.5 15.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
];
---

<Layout
  title="Services"
  description="AI-Automatisierungen, SaaS-Produkte, Trading-Algorithmen und AI-Agent-Systeme — WandaSystems baut B2B-Technologie, die messbare Ergebnisse liefert."
>
  <!-- Page Header -->
  <section class="pt-20 pb-16" aria-labelledby="services-page-heading">
    <div class="container-content">
      <div class="mb-4">
        <span class="badge">Services</span>
      </div>
      <h1 id="services-page-heading" class="text-heading-1 mb-5 text-text-primary max-w-2xl">
        Was wir bauen — und wie.
      </h1>
      <p class="text-body-lg text-text-secondary max-w-xl">
        Vier Kernbereiche. Gemeinsamer Nenner: Systems, die funktionieren,
        wenn Sie nicht hinschauen.
      </p>
    </div>
  </section>

  <!-- Service Sections -->
  {services.map((s, i) => (
    <section
      id={s.id}
      class:list={['section border-t border-border scroll-mt-20', i % 2 !== 0 ? 'bg-bg-secondary' : '']}
      aria-labelledby={`service-${s.id}`}
    >
      <div class="container-content">
        <div class="grid gap-12 lg:grid-cols-2 lg:gap-20 items-start">
          <!-- Left: Content -->
          <div>
            <div class="mb-5 flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 text-accent">
                <Fragment set:html={s.icon} />
              </div>
              <span class="badge">{s.badge}</span>
            </div>

            <h2 id={`service-${s.id}`} class="text-heading-2 mb-5 text-text-primary whitespace-pre-line">
              {s.title}
            </h2>

            <p class="text-body-lg text-text-secondary mb-6">{s.desc}</p>
            <p class="text-body text-text-secondary mb-8">{s.detail}</p>

            <a href="/contact" class="btn-primary">
              Projekt besprechen
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

          <!-- Right: Stack + Outcomes -->
          <div class="space-y-8">
            <!-- Outcomes -->
            <div>
              <p class="label-text mb-4">Was Sie erhalten</p>
              <ul class="space-y-3" role="list">
                {s.outcomes.map((o) => (
                  <li class="flex items-start gap-3">
                    <div class="mt-1 flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full bg-accent/15">
                      <svg width="8" height="8" viewBox="0 0 8 8" fill="none" aria-hidden="true">
                        <path d="M1.5 4l1.5 1.5 3-3" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    <span class="text-small text-text-secondary">{o}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Stack -->
            <div>
              <p class="label-text mb-3">Tech-Stack</p>
              <div class="flex flex-wrap gap-2">
                {s.stack.map((tech) => (
                  <span class="rounded-md border border-border bg-surface px-3 py-1.5 text-xs font-medium text-text-secondary">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Bottom CTA -->
  <section class="section border-t border-border" aria-labelledby="services-cta">
    <div class="container-content">
      <div class="mx-auto max-w-2xl text-center">
        <h2 id="services-cta" class="text-heading-2 mb-4 text-text-primary">
          Ihr Projekt passt nicht in eine Kategorie?
        </h2>
        <p class="text-body text-text-secondary mb-8">
          Gut. Die interessantesten Probleme tun das selten.
          Erzählen Sie uns davon.
        </p>
        <a href="/contact" class="btn-primary">
          Unverbindlich anfragen
        </a>
      </div>
    </div>
  </section>
</Layout>
