---
import Layout from '../layouts/Layout.astro';

const contactHref = `${import.meta.env.BASE_URL}contact/`;

const products = [
  {
    id: 'data-bot',
    badge: 'Instant Download · Python CLI Tool',
    price: '€29',
    title: 'Data Cleaning Bot',
    tagline: 'Messy CSVs in. Clean outputs out.',
    desc: 'A Python CLI script with README, sample files, and setup steps. Built for technical users who can run a basic Python environment.',
    outcomes: [
      'Removes duplicate rows automatically',
      'Normalizes formatting (phone, email, names)',
      'Validates and flags missing or invalid fields',
      'Exports clean CSV + Excel with a cleaning report',
    ],
    delivery: 'After payment: Stripe confirmation + fulfillment email with bundle link within 15 minutes (60-minute fallback maximum).',
    requirements: 'Requirements: Python 3.9+, pip, basic CLI knowledge. Not a no-code tool.',
    cta: 'Buy Data Cleaning Bot — €29',
    href: 'https://buy.stripe.com/28E14odfd8u6gPqbkQaVa01',
    primary: true,
  },
  {
    id: 'lead-scout',
    badge: 'Instant Download · Bring Your Own API Key',
    price: '€35',
    title: 'Lead-Scout (Google Places)',
    tagline: 'Works with your own Google Places API key.',
    desc: 'A Python CLI lead-extraction tool for technical users. The product path is API-first and no longer depends on brittle Google Maps selectors. Buyer provides their own Google Places API key.',
    outcomes: [
      'Google Places API v1 path instead of selector scraping',
      'Simple local setup via `.env` or one setup command',
      'Exports CRM-ready CSV + JSON output',
      'Website and ad-signal check remains included',
    ],
    delivery: 'After payment: fulfillment bundle with setup helper, `.env.example`, and buyer guide. You bring your own Google Places API key.',
    requirements: 'Requirements: Python 3.10+, requests, and your own Google Places API key with billing enabled on your Google Cloud project.',
    cta: 'Buy Lead-Scout — €35',
    href: 'https://buy.stripe.com/bJe00k0sr5hU1Uw60waVa00',
    primary: true,
  },
];

const rapidOffers = [
  {
    id: 'workflow-fix',
    title: 'Workflow Fix Pack (24h)',
    priceAnchor: 'from €149 (scope-confirmed)',
    desc: 'Repair of one broken automation/workflow path (trigger, routing, edge-cases, retries) with handover notes.',
    deliverable: 'Patched flow + test proof + rollback notes in <24h.',
  },
  {
    id: 'data-cleanup-sprint',
    title: 'Data Cleanup Sprint (24h)',
    priceAnchor: 'from €99 (scope-confirmed)',
    desc: 'One-time cleanup of CSV/CRM exports (dedupe, normalization, field validation) plus import-ready output.',
    deliverable: 'Clean dataset + change report + run command in <24h.',
  },
  {
    id: 'redirect-routing-repair',
    title: 'Redirect / Webhook Repair (24h)',
    priceAnchor: 'from €129 (scope-confirmed)',
    desc: 'Fix broken redirects/webhook glue paths, validate endpoint behavior, and add operational fallback notes.',
    deliverable: 'Working route/webhook + verification log + fallback path in <24h.',
  },
  {
    id: 'invoice-pdf-generator',
    title: 'Invoice PDF Generator Bundle (24h)',
    priceAnchor: '€49 fixed',
    desc: 'A local Python bundle that generates invoice PDFs from structured JSON input. Good fit when you need simple invoice generation without buying a whole billing platform.',
    deliverable: 'Python bundle + sample JSON + buyer guide + QA-verified sample PDF in <24h.',
  },
];

const services = [
  {
    id: 'automation',
    badge: 'Custom · Inquiry Required',
    title: 'AI Automation Systems',
    priceAnchor: 'Pricing after scope call',
    desc: 'We analyze your workflow and implement reliable n8n + Python automations with transparent handover documentation. Every project is scoped individually — no blind commitments.',
    outcomes: [
      'Reduce manual data entry close to zero',
      'API integrations across core business tools',
      'Monitoring and alerting on critical steps',
      'Implementation documentation for your team',
    ],
    stack: ['n8n', 'Python', 'FastAPI', 'PostgreSQL', 'Docker'],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L3 7v10l9 5 9-5V7L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M12 2v14M3 7l9 5 9-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    id: 'agents',
    badge: 'Custom · Inquiry Required',
    title: 'AI Agent Systems',
    priceAnchor: 'Pricing after scope call',
    desc: 'No chatbot demos: real agents that research, decide, and execute in your stack — with human-in-the-loop where it matters. Inquiry and scope clarification required.',
    outcomes: [
      'Agents aligned to your real workflows',
      'Tool access: web, databases, APIs, code execution',
      'Persistent memory and context management',
      'Human-in-the-loop at critical decision points',
    ],
    stack: ['Python', 'LangGraph / CrewAI', 'OpenAI / Anthropic', 'Vector DBs', 'Docker'],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="9" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M6 20c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M18 6l2.5-2.5M18 13l2.5 2.5M6 6L3.5 3.5M6 13L3.5 15.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    id: 'saas',
    badge: 'Long Scope · Not actively pitched',
    title: 'SaaS Product Development',
    priceAnchor: 'Only after scoped roadmap (not 24h deliverable)',
    desc: 'Available selectively for longer engagements. This is not part of our active rapid-delivery outreach offers.',
    outcomes: [
      'Full auth setup (OAuth, MFA)',
      'Stripe integration for subscriptions and one-time payments',
      'Multi-tenant architecture from day one',
      'Admin dashboard and usage analytics',
    ],
    stack: ['Next.js / Astro', 'Supabase', 'Stripe', 'TypeScript', 'Tailwind CSS'],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M7 8h4M7 11.5h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
];

// ⚡ Bolt: Pre-calculate filtered arrays in Astro frontmatter
// 💡 What: Moved `.filter()` calls from the JSX/template markup into the static setup block.
// 🎯 Why: Calculating derived state here ensures the filter operation runs only once during the build process, preventing redundant evaluations during template rendering and keeping the template logic clean.
// 📊 Impact: Micro-optimization for build speed and cleaner component architecture by separating logic from presentation.
const primaryProducts = products.filter((p) => p.primary);
const pausedProducts = products.filter((p) => !p.primary);
---

<Layout
  title="Services"
  description="Python tools and custom AI systems by WandaSystems. Data Cleaning Bot available now. Automation, agents, and SaaS builds by inquiry."
>
  <!-- Page Header -->
  <section class="relative pt-20 pb-16 overflow-hidden" aria-labelledby="services-page-heading">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 20% 50%, rgba(45, 27, 105, 0.3) 0%, transparent 60%);"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 80% 20%, rgba(6, 182, 212, 0.06) 0%, transparent 50%);"></div>
    </div>
    <div class="container-content relative">
      <div class="mb-4">
        <span class="badge">Services & Products</span>
      </div>
      <h1 id="services-page-heading" class="text-heading-1 mb-5 text-text-primary max-w-2xl">
        Tools that work.<br />Systems that scale.
      </h1>
      <p class="text-body-lg text-text-secondary max-w-xl">
        Buy instant fulfillment bundles now, or request custom AI implementation for your team.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="#products-heading" class="btn-primary">See instant products</a>
        <a href="#custom-heading" class="btn-secondary">Request custom implementation</a>
      </div>
    </div>
  </section>

  <!-- Products Section — Instant Buy -->
  <section class="section border-t border-border" aria-labelledby="products-heading">
    <div class="container-content">
      <div class="mb-10">
        <h2 id="products-heading" class="text-heading-2 text-text-primary mb-2">Instant Buy Products</h2>
        <p class="text-body text-text-secondary">Python CLI tools with README, sample files, and setup guidance. For technical users — not no-code.</p>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        {primaryProducts.map((p) => (
          <div
            class="rounded-2xl border p-8 flex flex-col relative overflow-hidden"
            style={p.primary
              ? 'background: linear-gradient(135deg, rgba(18, 8, 32, 0.95) 0%, rgba(45, 27, 105, 0.2) 100%); border-color: rgba(201, 168, 76, 0.35); box-shadow: 0 0 40px rgba(201,168,76,0.06);'
              : 'background: linear-gradient(135deg, rgba(18, 8, 32, 0.9) 0%, rgba(10, 10, 10, 0.6) 100%); border-color: rgba(255,255,255,0.08);'
            }
          >
            {p.primary && (
              <div class="absolute top-4 right-4">
                <span class="rounded-full px-3 py-1 text-xs font-semibold" style="background: rgba(201,168,76,0.15); color: #c9a84c; border: 1px solid rgba(201,168,76,0.3);">
                  Available
                </span>
              </div>
            )}

            <div class="mb-6">
              <span class="badge mb-3 inline-block">{p.badge}</span>
              <div class="flex items-baseline gap-3 mb-2">
                <h3 class="text-heading-2 text-text-primary">{p.title}</h3>
                <span class="text-2xl font-bold" style="color: #c9a84c;">{p.price}</span>
              </div>
              <p class="text-body text-brand-gold font-medium mb-3">{p.tagline}</p>
              <p class="text-body text-text-secondary">{p.desc}</p>
            </div>

            <ul class="space-y-2.5 mb-8 flex-1" role="list">
              {p.outcomes.map((o) => (
                <li class="flex items-start gap-3">
                  <div class="mt-1 flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full" style="background: rgba(201,168,76,0.15);">
                    <svg width="8" height="8" viewBox="0 0 8 8" fill="none" aria-hidden="true">
                      <path d="M1.5 4l1.5 1.5 3-3" stroke="#c9a84c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <span class="text-small text-text-secondary">{o}</span>
                </li>
              ))}
            </ul>

            {p.requirements && (
              <p class="mb-4 text-xs text-text-muted border border-border rounded-lg px-4 py-2" style="background: rgba(255,255,255,0.02);">
                ⚠️ {p.requirements}
              </p>
            )}
            {p.href ? (
              <a
                href={p.href}
                target="_blank"
                rel="noopener noreferrer"
                class={p.primary ? 'btn-primary text-center justify-center' : 'btn-secondary text-center justify-center'}
                style={p.primary ? '' : 'display: flex; align-items: center;'}
              >
                {p.cta}
                <span class="sr-only">(opens in a new tab)</span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="ml-2">
                  <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            ) : (
              <a
                href={contactHref}
                class="btn-secondary text-center justify-center"
                style="display: flex; align-items: center;"
              >
                {p.cta}
              </a>
            )}
            {p.delivery && <p class="mt-3 text-xs text-text-secondary">{p.delivery}</p>}
          </div>
        ))}
      </div>

      <!-- Trust signals -->
      <div class="mt-8 flex flex-wrap gap-6 items-center">
        <div class="flex items-center gap-2 text-text-secondary text-small">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 1l1.8 3.6L14 5.3l-3 2.9.7 4.1L8 10.4l-3.7 1.9.7-4.1-3-2.9 4.2-.7L8 1z" stroke="#c9a84c" stroke-width="1.2" stroke-linejoin="round"/></svg>
          Delivery target: within 15 minutes
        </div>
        <div class="flex items-center gap-2 text-text-secondary text-small">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="2" y="7" width="12" height="8" rx="2" stroke="#c9a84c" stroke-width="1.2"/><path d="M5 7V5a3 3 0 016 0v2" stroke="#c9a84c" stroke-width="1.2" stroke-linecap="round"/></svg>
          Secure checkout via Stripe
        </div>
        <div class="flex items-center gap-2 text-text-secondary text-small">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2v12M2 8h12" stroke="#c9a84c" stroke-width="1.5" stroke-linecap="round"/></svg>
          Questions? <a href="mailto:wanda.devops@gmail.com" class="text-brand-gold hover:underline ml-1">wanda.devops@gmail.com</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section border-t border-border" aria-labelledby="paused-products-heading">
    <div class="container-content">
      <div class="mb-8">
        <h2 id="paused-products-heading" class="text-heading-3 text-text-primary mb-2">Paused products and transparency</h2>
        <p class="text-body text-text-secondary">Paused offers stay visible for honesty, but they do not sit in the live buy path.</p>
      </div>
      <div class="grid gap-6 lg:grid-cols-2">
        {pausedProducts.map((p) => (
          <article class="rounded-2xl border border-border p-8" style="background: linear-gradient(135deg, rgba(18, 8, 32, 0.9) 0%, rgba(10, 10, 10, 0.6) 100%);">
            <span class="badge mb-3 inline-block">{p.badge}</span>
            <div class="flex items-baseline gap-3 mb-2">
              <h3 class="text-heading-3 text-text-primary">{p.title}</h3>
              <span class="text-xl font-semibold text-text-muted">{p.price}</span>
            </div>
            <p class="text-body text-brand-gold font-medium mb-3">{p.tagline}</p>
            <p class="text-body text-text-secondary mb-5">{p.desc}</p>
            <ul class="space-y-2.5 mb-6" role="list">
              {p.outcomes.map((o) => (
                <li class="flex items-start gap-3">
                  <div class="mt-1 flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full" style="background: rgba(201,168,76,0.15);">
                    <svg width="8" height="8" viewBox="0 0 8 8" fill="none" aria-hidden="true">
                      <path d="M1.5 4l1.5 1.5 3-3" stroke="#c9a84c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <span class="text-small text-text-secondary">{o}</span>
                </li>
              ))}
            </ul>
            <p class="mb-4 text-xs text-text-muted border border-border rounded-lg px-4 py-2" style="background: rgba(255,255,255,0.02);">
              ⚠️ {p.requirements}
            </p>
            <a href={contactHref} class="btn-secondary inline-flex items-center justify-center">
              {p.cta}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Rapid Delivery Offers (24h) -->
  <section class="section border-t border-border" aria-labelledby="rapid-heading">
    <div class="container-content">
      <div class="mb-10">
        <h2 id="rapid-heading" class="text-heading-2 text-text-primary mb-2">Rapid Delivery Offers (under 24h)</h2>
        <p class="text-body text-text-secondary">Active outreach focuses only on tightly scoped technical work we can deliver fast and safely.</p>
      </div>
      <div class="grid gap-6 lg:grid-cols-3">
        {rapidOffers.map((o) => (
          <article class="rounded-xl border border-border p-6" style="background: linear-gradient(135deg, rgba(18, 8, 32, 0.8) 0%, rgba(10, 10, 10, 0.5) 100%);">
            <h3 class="text-heading-3 text-text-primary mb-2">{o.title}</h3>
            <p class="text-small text-brand-gold mb-3">{o.priceAnchor}</p>
            <p class="text-body text-text-secondary mb-4">{o.desc}</p>
            <p class="text-xs text-text-muted mb-4">{o.deliverable}</p>
            <a href={`${contactHref}?service=other`} class="btn-secondary inline-flex">
              Request scope<span class="sr-only"> for {o.title}</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Custom Services -->
  <section class="section border-t border-border" aria-labelledby="custom-heading">
    <div class="container-content">
      <div class="mb-10">
        <h2 id="custom-heading" class="text-heading-2 text-text-primary mb-2">Custom Services by Inquiry</h2>
        <p class="text-body text-text-secondary">Every project is scoped individually. No fixed quote without a call — no commitment without scope clarity.</p>
      </div>

      <div class="space-y-0">
        {services.map((s, i) => (
          <div
            id={s.id}
            class:list={['py-10 border-b border-border last:border-b-0 grid gap-10 lg:grid-cols-2 lg:gap-16 items-start']}
          >
            <div>
              <div class="mb-4 flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-gold/10 text-brand-gold" style="box-shadow: 0 0 20px rgba(201,168,76,0.15);">
                  <Fragment set:html={s.icon} />
                </div>
                <span class="badge">{s.badge}</span>
              </div>
              <h3 class="text-heading-3 mb-2 text-text-primary">{s.title}</h3>
              <p class="text-small text-brand-gold mb-4">{s.priceAnchor}</p>
              <p class="text-body text-text-secondary mb-6">{s.desc}</p>
              <a href={`${contactHref}?service=${s.id}`} class="btn-secondary inline-flex items-center gap-2">
                Request project scope<span class="sr-only"> for {s.title}</span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
            <div class="space-y-6">
              <div class="rounded-xl p-5 border border-border" style="background: linear-gradient(135deg, rgba(18, 8, 32, 0.8) 0%, rgba(10, 10, 10, 0.6) 100%);">
                <p class="label-text mb-3">What you get</p>
                <ul class="space-y-2.5" role="list">
                  {s.outcomes.map((o) => (
                    <li class="flex items-start gap-3">
                      <div class="mt-1 flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full bg-brand-gold/15">
                        <svg width="8" height="8" viewBox="0 0 8 8" fill="none" aria-hidden="true">
                          <path d="M1.5 4l1.5 1.5 3-3" stroke="#c9a84c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </div>
                      <span class="text-small text-text-secondary">{o}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div>
                <p class="label-text mb-2">Tech stack</p>
                <div class="flex flex-wrap gap-2">
                  {s.stack.map((tech) => (
                    <span class="rounded-md border border-border bg-white/5 px-3 py-1.5 text-xs font-medium text-text-secondary hover:border-brand-gold/40 hover:text-brand-gold transition-colors duration-150">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="section border-t border-border" aria-labelledby="services-cta">
    <div class="container-content">
      <div class="mx-auto max-w-2xl text-center rounded-2xl p-10 relative overflow-hidden" style="background: linear-gradient(135deg, rgba(18, 8, 32, 0.9) 0%, rgba(10, 10, 10, 0.2) 50%, rgba(13, 8, 22, 0.9) 100%); border: 1px solid rgba(201, 168, 76, 0.15);">
        <div class="absolute inset-0 pointer-events-none rounded-2xl" style="box-shadow: inset 0 0 40px rgba(201,168,76,0.03);"></div>
        <h2 id="services-cta" class="text-heading-2 mb-4 text-text-primary relative">
          Not sure what you need?
        </h2>
        <p class="text-body text-text-secondary mb-8 relative">
          Describe your problem. We will tell you honestly if and how we can solve it.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center relative">
          <a href={contactHref} class="btn-primary">
            Get in touch
          </a>
          <a href="mailto:wanda.devops@gmail.com" class="btn-secondary">
            wanda.devops@gmail.com
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
