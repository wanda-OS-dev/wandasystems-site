---
import Layout from '../layouts/Layout.astro';

const products = [
  {
    id: 'lead-scout',
    badge: 'Instant Download · Python Script',
    price: '€35',
    title: 'Lead-Scout',
    tagline: 'Google Maps → CRM-ready CSV in minutes.',
    desc: 'Stop copying leads by hand. Give Lead-Scout a niche and a city — it returns a clean CSV with business names, addresses, phone numbers, websites, and an ad-pixel detection layer so you know who\'s already running paid marketing.',
    outcomes: [
      'Scrapes Google Maps by niche + city automatically',
      'Exports CRM-ready CSV (name, address, phone, website)',
      'Ad-pixel detection — prioritize businesses already spending',
      'No subscription. No SaaS. One script, yours forever.',
    ],
    cta: 'Buy Lead-Scout — €35',
    href: 'https://buy.stripe.com/bJe00k0sr5hU1Uw60waVa00',
    primary: true,
  },
  {
    id: 'data-bot',
    badge: 'Instant Download · Python Script',
    price: '€29',
    title: 'Data Cleaning Bot',
    tagline: 'Messy CSVs in. Clean data out.',
    desc: 'Duplicate rows, inconsistent formatting, missing fields, rogue commas — the Data Cleaning Bot handles all of it automatically. Drop in your CSV and get a normalized, deduplicated, import-ready file back.',
    outcomes: [
      'Deduplicates rows automatically',
      'Normalizes formatting (phone, email, names)',
      'Validates and flags missing/invalid fields',
      'Works on any CSV — no config required.',
    ],
    cta: 'Buy Data Cleaning Bot — €29',
    href: 'https://buy.stripe.com/28E14odfd8u6gPqbkQaVa01',
    primary: false,
  },
];

const services = [
  {
    id: 'automation',
    badge: 'Custom Service',
    title: 'AI-Automatisierungen',
    desc: 'Manuelle Prozesse kosten Zeit, Geld und Nerven. Wir analysieren Ihre Workflows und bauen n8n-Pipelines und Python-Skripte, die zuverlässig laufen — ohne Blackbox-Code.',
    outcomes: [
      'Manuelle Dateneingabe auf 0 reduziert',
      'API-Integrationen zwischen allen Business-Tools',
      'Monitoring & Alerting für jeden kritischen Schritt',
      'Dokumentation und Übergabe für interne Teams',
    ],
    stack: ['n8n', 'Python', 'FastAPI', 'PostgreSQL', 'Docker'],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2L3 7v10l9 5 9-5V7L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M12 2v14M3 7l9 5 9-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    id: 'agents',
    badge: 'Custom Service',
    title: 'AI-Agent-Systeme',
    desc: 'Über Chatbots hinaus: Agenten, die recherchieren, entscheiden und handeln — eingebettet in Ihre Infrastruktur, mit menschlicher Oversight wo sie gebraucht wird.',
    outcomes: [
      'Custom-Agenten für Ihre spezifischen Workflows',
      'Tool-Nutzung: Web, DB, APIs, Code-Execution',
      'Persistentes Gedächtnis und Kontext-Management',
      'Human-in-the-loop für kritische Entscheidungen',
    ],
    stack: ['Python', 'LangGraph / CrewAI', 'OpenAI / Anthropic', 'Vector DBs', 'Docker'],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="9" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M6 20c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M18 6l2.5-2.5M18 13l2.5 2.5M6 6L3.5 3.5M6 13L3.5 15.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
  {
    id: 'saas',
    badge: 'Custom Service',
    title: 'SaaS-Produkte',
    desc: 'Von der Idee zum marktfähigen Produkt. In 4–8 Wochen von Konzept zur ersten zahlenden Subscription — auf bewährtem Stack, der wächst wenn Sie wachsen.',
    outcomes: [
      'Vollständiges Auth-System (OAuth, MFA)',
      'Stripe-Integration für Subscriptions und One-Time Payments',
      'Multi-Tenant-Architektur von Anfang an',
      'Admin-Dashboard & Usage-Analytics',
    ],
    stack: ['Next.js / Astro', 'Supabase', 'Stripe', 'TypeScript', 'Tailwind CSS'],
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M7 8h4M7 11.5h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
];
---

<Layout
  title="Services"
  description="Instant-download tools and custom AI systems from WandaSystems. Lead-Scout, Data Cleaning Bot, and bespoke automation for B2B teams."
>
  <!-- Page Header -->
  <section class="relative pt-20 pb-16 overflow-hidden" aria-labelledby="services-page-heading">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 20% 50%, rgba(45, 27, 105, 0.3) 0%, transparent 60%);"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 80% 20%, rgba(6, 182, 212, 0.06) 0%, transparent 50%);"></div>
    </div>
    <div class="container-content relative">
      <div class="mb-4">
        <span class="badge">Services & Products</span>
      </div>
      <h1 id="services-page-heading" class="text-heading-1 mb-5 text-text-primary max-w-2xl">
        Tools that work.<br />Systems that scale.
      </h1>
      <p class="text-body-lg text-text-secondary max-w-xl">
        Instant-download scripts for lead gen and data work — or custom AI automation built for your specific stack.
      </p>
    </div>
  </section>

  <!-- Products Section — Instant Buy -->
  <section class="section border-t border-border" aria-labelledby="products-heading">
    <div class="container-content">
      <div class="mb-10">
        <h2 id="products-heading" class="text-heading-2 text-text-primary mb-2">Ready to buy right now</h2>
        <p class="text-body text-text-secondary">Python scripts. Instant download. No subscription, no setup call.</p>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        {products.map((p) => (
          <div
            class="rounded-2xl border p-8 flex flex-col relative overflow-hidden"
            style={p.primary
              ? 'background: linear-gradient(135deg, rgba(18, 8, 32, 0.95) 0%, rgba(45, 27, 105, 0.2) 100%); border-color: rgba(201, 168, 76, 0.35); box-shadow: 0 0 40px rgba(201,168,76,0.06);'
              : 'background: linear-gradient(135deg, rgba(18, 8, 32, 0.9) 0%, rgba(10, 10, 10, 0.6) 100%); border-color: rgba(255,255,255,0.08);'
            }
          >
            {p.primary && (
              <div class="absolute top-4 right-4">
                <span class="rounded-full px-3 py-1 text-xs font-semibold" style="background: rgba(201,168,76,0.15); color: #c9a84c; border: 1px solid rgba(201,168,76,0.3);">
                  Most popular
                </span>
              </div>
            )}

            <div class="mb-6">
              <span class="badge mb-3 inline-block">{p.badge}</span>
              <div class="flex items-baseline gap-3 mb-2">
                <h3 class="text-heading-2 text-text-primary">{p.title}</h3>
                <span class="text-2xl font-bold" style="color: #c9a84c;">{p.price}</span>
              </div>
              <p class="text-body text-brand-gold font-medium mb-3">{p.tagline}</p>
              <p class="text-body text-text-secondary">{p.desc}</p>
            </div>

            <ul class="space-y-2.5 mb-8 flex-1" role="list">
              {p.outcomes.map((o) => (
                <li class="flex items-start gap-3">
                  <div class="mt-1 flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full" style="background: rgba(201,168,76,0.15);">
                    <svg width="8" height="8" viewBox="0 0 8 8" fill="none" aria-hidden="true">
                      <path d="M1.5 4l1.5 1.5 3-3" stroke="#c9a84c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <span class="text-small text-text-secondary">{o}</span>
                </li>
              ))}
            </ul>

            <a
              href={p.href}
              target="_blank"
              rel="noopener noreferrer"
              class={p.primary ? 'btn-primary text-center justify-center' : 'btn-secondary text-center justify-center'}
              style={p.primary ? '' : 'display: flex; align-items: center;'}
            >
              {p.cta}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="ml-2">
                <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        ))}
      </div>

      <!-- Trust signals -->
      <div class="mt-8 flex flex-wrap gap-6 items-center">
        <div class="flex items-center gap-2 text-text-secondary text-small">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 1l1.8 3.6L14 5.3l-3 2.9.7 4.1L8 10.4l-3.7 1.9.7-4.1-3-2.9 4.2-.7L8 1z" stroke="#c9a84c" stroke-width="1.2" stroke-linejoin="round"/></svg>
          Instant delivery — no waiting
        </div>
        <div class="flex items-center gap-2 text-text-secondary text-small">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="2" y="7" width="12" height="8" rx="2" stroke="#c9a84c" stroke-width="1.2"/><path d="M5 7V5a3 3 0 016 0v2" stroke="#c9a84c" stroke-width="1.2" stroke-linecap="round"/></svg>
          Secure checkout via Stripe
        </div>
        <div class="flex items-center gap-2 text-text-secondary text-small">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2v12M2 8h12" stroke="#c9a84c" stroke-width="1.5" stroke-linecap="round"/></svg>
          Questions? <a href="mailto:wanda.devops@gmail.com" class="text-brand-gold hover:underline ml-1">wanda.devops@gmail.com</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Custom Services -->
  <section class="section border-t border-border" aria-labelledby="custom-heading">
    <div class="container-content">
      <div class="mb-10">
        <h2 id="custom-heading" class="text-heading-2 text-text-primary mb-2">Custom services</h2>
        <p class="text-body text-text-secondary">Need something built specifically for your stack? We do that too.</p>
      </div>

      <div class="space-y-0">
        {services.map((s, i) => (
          <div
            class:list={['py-10 border-b border-border last:border-b-0 grid gap-10 lg:grid-cols-2 lg:gap-16 items-start']}
          >
            <div>
              <div class="mb-4 flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-gold/10 text-brand-gold" style="box-shadow: 0 0 20px rgba(201,168,76,0.15);">
                  <Fragment set:html={s.icon} />
                </div>
                <span class="badge">{s.badge}</span>
              </div>
              <h3 class="text-heading-3 mb-4 text-text-primary">{s.title}</h3>
              <p class="text-body text-text-secondary mb-6">{s.desc}</p>
              <a href="/wandasystems-site/contact" class="btn-secondary inline-flex items-center gap-2">
                Projekt besprechen
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
            <div class="space-y-6">
              <div class="rounded-xl p-5 border border-border" style="background: linear-gradient(135deg, rgba(18, 8, 32, 0.8) 0%, rgba(10, 10, 10, 0.6) 100%);">
                <p class="label-text mb-3">Was Sie erhalten</p>
                <ul class="space-y-2.5" role="list">
                  {s.outcomes.map((o) => (
                    <li class="flex items-start gap-3">
                      <div class="mt-1 flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full bg-brand-gold/15">
                        <svg width="8" height="8" viewBox="0 0 8 8" fill="none" aria-hidden="true">
                          <path d="M1.5 4l1.5 1.5 3-3" stroke="#c9a84c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </div>
                      <span class="text-small text-text-secondary">{o}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div>
                <p class="label-text mb-2">Stack</p>
                <div class="flex flex-wrap gap-2">
                  {s.stack.map((tech) => (
                    <span class="rounded-md border border-border bg-white/5 px-3 py-1.5 text-xs font-medium text-text-secondary hover:border-brand-gold/40 hover:text-brand-gold transition-colors duration-150">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="section border-t border-border" aria-labelledby="services-cta">
    <div class="container-content">
      <div class="mx-auto max-w-2xl text-center rounded-2xl p-10 relative overflow-hidden" style="background: linear-gradient(135deg, rgba(18, 8, 32, 0.9) 0%, rgba(10, 10, 10, 0.2) 50%, rgba(13, 8, 22, 0.9) 100%); border: 1px solid rgba(201, 168, 76, 0.15);">
        <div class="absolute inset-0 pointer-events-none rounded-2xl" style="box-shadow: inset 0 0 40px rgba(201,168,76,0.03);"></div>
        <h2 id="services-cta" class="text-heading-2 mb-4 text-text-primary relative">
          Not sure what you need?
        </h2>
        <p class="text-body text-text-secondary mb-8 relative">
          Tell us your problem. We'll tell you if we can solve it — and how.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center relative">
          <a href="/wandasystems-site/contact" class="btn-primary">
            Get in touch
          </a>
          <a href="mailto:wanda.devops@gmail.com" class="btn-secondary">
            wanda.devops@gmail.com
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
