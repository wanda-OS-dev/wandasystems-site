---
import Layout from '../layouts/Layout.astro';

const cases = [
  {
    id: 'lead-automation',
    tag: 'AI Automation',
    industry: 'B2B SaaS',
    title: 'Lead qualification fully automated',
    challenge: 'A B2B SaaS company spent 3+ hours per day manually reviewing inbound leads, creating CRM entries, and writing follow-up emails.',
    solution: 'We built an n8n workflow that automatically classifies leads, enriches them (Clearbit, LinkedIn), writes to CRM, and sends personalized first-touch emails.',
    results: [
      '94% reduction in manual lead-processing time',
      'Response time reduced from 8 hours to 3 minutes',
      'Conversion rate +22% through faster response',
    ],
    tech: ['n8n', 'OpenAI', 'HubSpot API', 'Clearbit'],
  },
  {
    id: 'saas-launch',
    tag: 'SaaS Product',
    industry: 'PropTech',
    title: 'SaaS platform launched in 6 weeks',
    challenge: 'A startup founder had a clear product idea for real estate, but no in-house tech team and a tight budget for long agency development cycles.',
    solution: 'Using SupaStarter, we delivered a full multi-tenant SaaS platform with Stripe subscriptions, document management, and a reporting dashboard.',
    results: [
      'Live after 42 days',
      'First paying customers in week 7',
      '€4,200 MRR after 3 months',
    ],
    tech: ['Next.js', 'Supabase', 'Stripe', 'Vercel'],
  },
  {
    id: 'api-modernization',
    tag: 'API Integration',
    industry: 'E-Commerce',
    title: 'Order, CRM, and ERP data synchronized in real time',
    challenge: 'An e-commerce company operated across three data silos: shop system, CRM, and ERP. Cross-team reports were error-prone and often a day behind.',
    solution: 'We implemented robust API integrations with event queues, retry logic, and monitoring so changes across systems were harmonized in real time.',
    results: [
      'Invalid data records reduced by 87%',
      'Reporting moved from daily batches to real-time',
      'Support tickets for data mismatches significantly reduced',
    ],
    tech: ['Python', 'FastAPI', 'PostgreSQL', 'Webhook Architecture'],
  },
  {
    id: 'agent-research',
    tag: 'AI Agent System',
    industry: 'Consulting',
    title: 'Research agent replaced 40h/week of manual work',
    challenge: 'A consulting firm produced weekly market analyses for clients — a process that consumed 40+ analyst hours and still ran late.',
    solution: 'We built a multi-agent system with LangGraph: research agent (web/news APIs), analysis agent (synthesis + evaluation), and report agent (document generation).',
    results: [
      'Analysis time reduced from 40h to 45 minutes',
      'Reports generated automatically in client-ready format',
      'Fully integrated into existing workflow tools',
    ],
    tech: ['Python', 'LangGraph', 'OpenAI', 'Tavily', 'Notion API'],
  },
];
---

<Layout
  title="Case Studies"
  description="Real outcomes, real projects — how WandaSystems builds AI systems for B2B clients that make a measurable difference."
>
  <!-- Header -->
  <section class="pt-20 pb-16" aria-labelledby="cases-heading">
    <div class="container-content">
      <span class="badge mb-4 inline-block">Case Studies</span>
      <h1 id="cases-heading" class="text-heading-1 mb-5 text-text-primary max-w-2xl">
        Outcomes, not promises.
      </h1>
      <p class="text-body-lg text-text-secondary max-w-xl">
        Real projects, real numbers. All cases are published with client approval;
        details on request.
      </p>
    </div>
  </section>

  <!-- Cases -->
  <div class="border-t border-border">
    {cases.map((c, i) => (
      <article
        class:list={['section border-b border-border last:border-b-0 scroll-mt-20', i % 2 !== 0 ? 'bg-bg-secondary' : '']}
        id={c.id}
      >
        <div class="container-content">
          <div class="grid gap-12 lg:grid-cols-3 lg:gap-16">
            <!-- Meta -->
            <div class="lg:col-span-1">
              <span class="badge mb-4 inline-block">{c.tag}</span>
              <p class="label-text mb-2">{c.industry}</p>
              <h2 class="text-heading-3 mb-4 text-text-primary">{c.title}</h2>
              <div class="flex flex-wrap gap-2">
                {c.tech.map((t) => (
                  <span class="rounded-md border border-border bg-surface px-2.5 py-1 text-xs text-text-muted">
                    {t}
                  </span>
                ))}
              </div>
            </div>

            <!-- Content -->
            <div class="lg:col-span-2 grid gap-8 sm:grid-cols-2">
              <div>
                <p class="label-text mb-3">Starting point</p>
                <p class="text-small text-text-secondary leading-relaxed">{c.challenge}</p>
              </div>
              <div>
                <p class="label-text mb-3">Our solution</p>
                <p class="text-small text-text-secondary leading-relaxed">{c.solution}</p>
              </div>
              <div class="sm:col-span-2">
                <p class="label-text mb-4">Results</p>
                <ul class="grid gap-3 sm:grid-cols-3" role="list">
                  {c.results.map((r) => (
                    <li class="rounded-xl border border-brand-gold/20 bg-brand-gold/5 px-4 py-3">
                      <p class="text-small font-medium text-text-primary">{r}</p>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>

  <!-- CTA -->
  <section class="section" aria-labelledby="cases-cta">
    <div class="container-content">
      <div class="mx-auto max-w-2xl text-center">
        <h2 id="cases-cta" class="text-heading-2 mb-4 text-text-primary">
          Your next success project?
        </h2>
        <p class="text-body text-text-secondary mb-8">
          Let’s find out what outcomes are possible in your context.
        </p>
        <a href="/wandasystems-site/contact" class="btn-primary">
          Book a free call
        </a>
      </div>
    </div>
  </section>
</Layout>
