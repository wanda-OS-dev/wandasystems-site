---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import checkWebGLScript from '../scripts/check-webgl.js?raw';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description = 'WandaSystems — AI Automations, SaaS Products, and API Integrations for B2B.',
  ogImage = '/wandasystems-site/og-image.png',
  canonical,
} = Astro.props;

const siteBase = Astro.site ?? 'https://wanda-os-dev.github.io/wandasystems-site/';
const canonicalURL = canonical ?? new URL(Astro.url.pathname, siteBase);
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title} | WandaSystems</title>
    <meta name="title" content={`${title} | WandaSystems`} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/wandasystems-site/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/wandasystems-site/favicon.svg" />
    <link rel="apple-touch-icon" href="/wandasystems-site/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | WandaSystems`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="WandaSystems" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={`${title} | WandaSystems`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "WandaSystems",
      "url": "https://wanda-os-dev.github.io/wandasystems-site/",
      "description": description,
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "sales",
        "email": "wanda.devops@gmail.com"
      }
    }).replace(/</g, '\\u003c')} />

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- ⚡ Bolt: Added preconnect for n8n and Stripe -->
    <!-- 💡 What: Establishing early network connections to critical third-party domains. -->
    <!-- 🎯 Why: DNS/TCP/TLS handshakes take time. Preconnecting reduces latency when the user clicks a checkout link or submits the form. -->
    <!-- 📊 Impact: Faster time-to-interactive for form submissions and checkout navigations. -->
    <link rel="preconnect" href="https://buy.stripe.com" crossorigin />
    <link rel="preconnect" href="https://wanda.lazytechlab.de" crossorigin />
    <!-- ⚡ Bolt: Added preload for critical web fonts -->
    <!-- 💡 What: Paired the async stylesheet load (media="print") with a preload hint. -->
    <!-- 🎯 Why: The print/onload pattern defers render-blocking, but without a preload, the browser discovers the fetch late. Preloading initiates the fetch immediately, accelerating text rendering. -->
    <!-- 📊 Impact: Significantly improves First Contentful Paint (FCP) and prevents FOUT/FOIT by having the font CSS ready sooner. -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- WebGL safety gate: immersive layers must never block business content -->
    <script is:inline set:html={checkWebGLScript}></script>

    <!-- WandaSystems Analytics (DSGVO-konform, kein Cookie, kein PII) -->
    <script is:inline define:vars={{
      sbKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY
    }}>
      // 🛡️ Sentinel: Removed hardcoded API key
      const SB_URL = 'https://xotcufmlrfdthnpeasqi.supabase.co';

      function track(eventType, data) {
        if (!sbKey) return; // 🛡️ Sentinel: Fail securely if key is missing

        data = data || {};
        fetch(SB_URL + '/rest/v1/conversion_events', {
          method: 'POST',
          keepalive: true, // 🛡️ Sentinel: Ensure fire-and-forget requests complete reliably
          headers: {
            'Content-Type': 'application/json',
            'apikey': sbKey,
            'Authorization': 'Bearer ' + sbKey
          },
          body: JSON.stringify({
            event_type: eventType,
            source: document.referrer || 'direct',
            product_id: data.product || null,
            metadata: { page: window.location.pathname, ua: navigator.userAgent.substring(0, 100) }
          })
        }).catch(function() {});
      }

      track('page_view');

      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('a[href*=gumroad.com], a[href*=buy.stripe.com]').forEach(function(el) {
          el.addEventListener('click', function() {
            track('product_click', { product: el.textContent.trim().substring(0, 50), url: el.href });
          });
        });
      });
    </script>
  </head>
  <body class="flex min-h-full flex-col bg-brand-black">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 z-[100] btn-primary"
    >
      Skip to content
    </a>
    <!-- Global atmospheric background -->
    <div class="pointer-events-none fixed inset-0 z-0 wanda-grid-bg opacity-30" aria-hidden="true"></div>
    <div class="pointer-events-none fixed inset-0 z-0" aria-hidden="true">
      <div class="absolute top-0 right-0 w-[600px] h-[400px] rounded-full blur-[140px] opacity-[0.08]" style="background: radial-gradient(circle, #1a0a2e 0%, transparent 70%);"></div>
      <div class="absolute bottom-1/4 left-0 w-80 h-80 rounded-full blur-[120px] opacity-[0.06]" style="background: radial-gradient(circle, #c9a84c 0%, transparent 70%);"></div>
    </div>
    <Header />
    <main id="main-content" tabindex="-1" class="relative z-10 flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
