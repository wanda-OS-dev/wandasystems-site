--- src/components/Header.astro
+++ src/components/Header.astro
@@ -128,6 +128,34 @@
     menu?.classList.toggle('hidden');
     btn.setAttribute('aria-expanded', String(!isOpen));
     btn.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
+
+    // 🎨 Palette: Ensure focus stays within or returns appropriately when closed
+    if (!isOpen) {
+      // When opening, focus the first interactive element inside
+      const firstLink = menu?.querySelector('a');
+      firstLink?.focus();
+    } else {
+      // When closing, return focus to the toggle button
+      btn?.focus();
+    }
+  });
+
+  // 🎨 Palette: Close on Escape key for better keyboard accessibility
+  document.addEventListener('keydown', (e) => {
+    const isOpen = menu?.classList.contains('hidden') === false;
+    if (isOpen && e.key === 'Escape') {
+      btn?.click();
+    }
+  });
+
+  // 🎨 Palette: Close on outside click
+  document.addEventListener('click', (e) => {
+    const isOpen = menu?.classList.contains('hidden') === false;
+    if (isOpen && !menu?.contains(e.target as Node) && !btn?.contains(e.target as Node)) {
+      menu?.classList.add('hidden');
+      btn?.setAttribute('aria-expanded', 'false');
+      btn?.setAttribute('aria-label', 'Open menu');
+    }
   });
 </script>
